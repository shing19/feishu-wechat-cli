{
  "name": "feishu-wechat-cli",
  "version": "0.1.0",
  "description": "CLI for publishing Feishu docs to WeChat Official Account drafts",
  "author": "shing",
  "license": "MIT",
  "keywords": [
    "feishu",
    "lark",
    "wechat",
    "weixin",
    "official-account",
    "publishing",
    "markdown"
  ],
  "type": "module",
  "bin": {
    "feishu-wechat": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    "scripts/generate-cover.py"
  ],
  "homepage": "https://github.com/your-org/feishu-wechat-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/feishu-wechat-cli.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/feishu-wechat-cli/issues"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "server": "pnpm build && pnpm dotenv -e .env -- node ./dist/cli.js serve",
    "test:cli": "vitest run tests/cli.test.ts",
    "test:render": "vitest run tests/render.test.ts",
    "test:publish": "vitest run tests/publish.test.ts",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@wenyan-md/core": "^2.0.8",
    "commander": "^14.0.0",
    "express": "^5.2.1",
    "form-data-encoder": "^4.1.0",
    "formdata-node": "^6.0.3",
    "jsdom": "^27.4.0",
    "multer": "^2.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "dotenv-cli": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
